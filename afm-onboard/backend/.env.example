# =============================================================================
# AFM Onboard Backend - Environment Variables Example
# =============================================================================
# SECURITY: Никогда не коммитьте реальные секреты в git!
# Скопируйте этот файл в .env и заполните реальными значениями.
# =============================================================================

# Режим работы приложения
NODE_ENV=development
PORT=8080

# =============================================================================
# DATABASE
# =============================================================================
# SECURITY: Используйте сложный пароль для базы данных в production
DATABASE_URL="postgresql://postgres:YOUR_SECURE_PASSWORD@127.0.0.1:5432/afm?schema=public"

# =============================================================================
# JWT Authentication
# =============================================================================
# Время жизни access токена (рекомендуется 15 минут)
JWT_ACCESS_TTL=15m

# Время жизни refresh токена (рекомендуется 30 дней)
JWT_REFRESH_TTL=30d

# SECURITY: Сгенерируйте уникальный секрет минимум 64 символа!
# Можно сгенерировать командой: openssl rand -hex 32
JWT_SECRET="GENERATE_YOUR_OWN_SECRET_AT_LEAST_64_CHARACTERS_LONG"

# =============================================================================
# Security
# =============================================================================
# Количество раундов bcrypt для хеширования паролей
BCRYPT_ROUNDS=12

# Rate limiting для auth endpoints (запросов в минуту)
RATE_LIMIT_AUTH=10

# Rate limiting для общих endpoints (запросов в минуту)
RATE_LIMIT_GENERAL=60

# Максимальный размер загружаемых файлов в МБ
MAX_UPLOAD_MB=200

# =============================================================================
# CORS
# =============================================================================
# Разрешённые домены для CORS (через запятую)
# SECURITY: В production укажите только доверенные домены
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Email (SMTP)
# =============================================================================
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# =============================================================================
# S3 / MinIO (для хранения файлов)
# =============================================================================
# SECURITY: Используйте уникальные credentials для production
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=YOUR_S3_ACCESS_KEY
S3_SECRET_KEY=YOUR_S3_SECRET_KEY
S3_BUCKET=afm-uploads

# =============================================================================
# Prisma
# =============================================================================
PRISMA_CLIENT_ENGINE_TYPE=wasm
