NODE_ENV=development
PORT=8080

DATABASE_URL="postgresql://postgres:postgres@db:5432/afm?schema=public"

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_SECRET="afm-local-dev-secret-change-in-production-min-64-chars-long-1234567890"

BCRYPT_ROUNDS=12

SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

S3_ENDPOINT=http://minio:9000
S3_BUCKET=afm-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

MAX_UPLOAD_MB=200
RATE_LIMIT_AUTH=10
RATE_LIMIT_GENERAL=60

PRISMA_CLIENT_ENGINE_TYPE=wasm
