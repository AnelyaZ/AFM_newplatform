# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/afm_onboard"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# Application Configuration
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"

# Email Configuration (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@afm-onboard.kz"

# File Upload Configuration
MAX_FILE_SIZE=209715200
UPLOAD_PATH="./uploads"

# S3/MinIO Configuration (optional)
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="afm-media"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_REGION="us-east-1"

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Logging Configuration
LOG_LEVEL="info"
LOG_FILE="./logs/app.log"

# Admin Configuration
ADMIN_EMAIL="admin@afm-onboard.kz"
ADMIN_PASSWORD="change-this-password"

# Test Configuration
TEST_DATABASE_URL="postgresql://username:password@localhost:5432/afm_onboard_test"
